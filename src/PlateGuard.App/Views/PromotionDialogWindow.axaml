<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.PromotionDialogWindow"
        x:DataType="vm:PromotionDialogViewModel"
        d:DesignWidth="720"
        d:DesignHeight="520"
        Title="Promotion"
        Width="720"
        Height="520"
        MinWidth="660"
        MinHeight="480"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:PromotionDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Margin="24,24,24,12">
            <StackPanel Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding DialogTitle}"
                               Classes="pageTitle"/>
                    <TextBlock Text="Promotion name is required. Dates are optional."
                               Classes="muted"/>
                </StackPanel>

                <Border Classes="surfaceCard"
                        Padding="18">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="16"
                          RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Promotion Name *"
                                       Classes="label"/>
                            <TextBox Text="{Binding PromotionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Description"
                                       Classes="label"/>
                            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     Height="110"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Start Date"
                                       Classes="label"/>
                            <TextBox Text="{Binding StartDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="yyyy-MM-dd"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="End Date"
                                       Classes="label"/>
                            <TextBox Text="{Binding EndDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="yyyy-MM-dd"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Status"
                                       Classes="label"/>
                            <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Content="Active promotion"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="softCard"
                        Padding="14,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="muted"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1,1,0,0"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Required: promotion name."
                           VerticalAlignment="Center"
                           Classes="subtle"/>
                <Button Grid.Column="1"
                        Classes="secondary"
                        MinWidth="110"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        Classes="primary"
                        MinWidth="130"
                        Command="{Binding SaveCommand}"
                        Content="{Binding SaveButtonText}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
