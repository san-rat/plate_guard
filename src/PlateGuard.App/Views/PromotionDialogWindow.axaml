<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.PromotionDialogWindow"
        x:DataType="vm:PromotionDialogViewModel"
        d:DesignWidth="720"
        d:DesignHeight="540"
        Title="Promotion"
        Width="720"
        Height="540"
        MinWidth="680"
        MinHeight="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:PromotionDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto"
          Background="#F1F5F9">
        <ScrollViewer Margin="20">
            <StackPanel Spacing="16">
                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="{Binding DialogTitle}"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Create or update a promotion, date window, and active status."
                                   Foreground="#475569"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="16"
                          RowDefinitions="Auto,Auto,Auto,Auto">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Promotion Name *"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding PromotionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Description"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     Height="110"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Start Date"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding StartDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="yyyy-MM-dd"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="End Date"
                                       FontWeight="SemiBold"/>
                            <TextBox Text="{Binding EndDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="yyyy-MM-dd"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Status"
                                       FontWeight="SemiBold"/>
                            <CheckBox IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Content="Active promotion"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#475569"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1,1,0,0"
                Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Required field: promotion name."
                           VerticalAlignment="Center"
                           Foreground="#475569"/>
                <Button Grid.Column="1"
                        MinWidth="110"
                        Height="40"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        MinWidth="130"
                        Height="40"
                        Command="{Binding SaveCommand}"
                        Content="{Binding SaveButtonText}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
