<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.EditUsageWindow"
        x:DataType="vm:EditUsageDialogViewModel"
        d:DesignWidth="840"
        d:DesignHeight="700"
        Title="Edit Usage"
        Width="840"
        Height="700"
        MinWidth="760"
        MinHeight="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:EditUsageDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Margin="24,24,24,12">
            <StackPanel Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Edit Usage"
                               Classes="pageTitle"/>
                    <TextBlock Text="Vehicle number and promotion stay fixed to protect uniqueness."
                               Classes="muted"/>
                </StackPanel>

                <Border Classes="surfaceCard"
                        Padding="18">
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="16"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Vehicle Number"
                                       Classes="label"/>
                            <Border Classes="softCard"
                                    Padding="12,10">
                                <TextBlock Text="{Binding VehicleNumberDisplay}"
                                           Classes="value"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="6">
                            <TextBlock Text="Promotion"
                                       Classes="label"/>
                            <Border Classes="softCard"
                                    Padding="12,10">
                                <TextBlock Text="{Binding PromotionName}"
                                           Classes="value"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Service Date"
                                       Classes="label"/>
                            <TextBox Text="{Binding ServiceDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="yyyy-MM-dd"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Phone Number *"
                                       Classes="label"/>
                            <TextBox Text="{Binding PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Owner Name"
                                       Classes="label"/>
                            <TextBox Text="{Binding OwnerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Brand"
                                       Classes="label"/>
                            <TextBox Text="{Binding Brand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3"
                                    Margin="0,14,0,0"
                                    Spacing="6">
                            <TextBlock Text="Model"
                                       Classes="label"/>
                            <TextBox Text="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid Grid.Row="4"
                              Grid.ColumnSpan="2"
                              Margin="0,14,0,0"
                              ColumnDefinitions="*,*,*,*"
                              ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Mileage"
                                           Classes="label"/>
                                <TextBox Text="{Binding MileageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Normal Price"
                                           Classes="label"/>
                                <TextBox Text="{Binding NormalPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Spacing="6">
                                <TextBlock Text="Discounted Price"
                                           Classes="label"/>
                                <TextBox Text="{Binding DiscountedPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3"
                                        Spacing="6">
                                <TextBlock Text="Amount Paid"
                                           Classes="label"/>
                                <TextBox Text="{Binding AmountPaidText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Classes="surfaceCard"
                        Padding="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Notes"
                                   Classes="sectionTitle"/>
                        <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 Height="120"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>
                </Border>

                <Border Classes="softCard"
                        Padding="14,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="muted"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1,1,0,0"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Required: phone number."
                           VerticalAlignment="Center"
                           Classes="subtle"/>
                <Button Grid.Column="1"
                        Classes="secondary"
                        MinWidth="110"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        Classes="primary"
                        MinWidth="110"
                        Command="{Binding SaveCommand}"
                        Content="Save"/>
            </Grid>
        </Border>
    </Grid>
</Window>
