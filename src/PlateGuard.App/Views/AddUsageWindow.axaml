<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:core="using:PlateGuard.Core.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.AddUsageWindow"
        x:DataType="vm:AddUsageDialogViewModel"
        d:DesignWidth="840"
        d:DesignHeight="700"
        Title="Add Usage"
        Width="840"
        Height="700"
        MinWidth="760"
        MinHeight="620"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:AddUsageDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <ScrollViewer Margin="24,24,24,12">
            <StackPanel Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Add Usage"
                               Classes="pageTitle"/>
                    <TextBlock Text="{Binding EntryModeTitle}"
                               Classes="sectionTitle"/>
                    <TextBlock Text="{Binding EntryModeMessage}"
                               Classes="muted"/>
                </StackPanel>

                <Border Classes="surfaceCard"
                        Padding="18">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Core Details"
                                   Classes="sectionTitle"/>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="16"
                              RowDefinitions="Auto,Auto,Auto,Auto">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Vehicle Number *"
                                           Classes="label"/>
                                <TextBox Text="{Binding VehicleNumberRaw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsExistingVehicle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Normalized Preview"
                                           Classes="label"/>
                                <Border Classes="softCard"
                                        Padding="12,10">
                                    <TextBlock Text="{Binding NormalizedVehicleNumber}"
                                               Classes="value"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Spacing="6">
                                <TextBlock Text="Promotion *"
                                           Classes="label"/>
                                <ComboBox ItemsSource="{Binding AvailablePromotions}"
                                          SelectedItem="{Binding SelectedPromotion, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="core:Promotion">
                                            <TextBlock Text="{Binding PromotionName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Phone Number *"
                                           Classes="label"/>
                                <TextBox Text="{Binding PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Spacing="6">
                                <TextBlock Text="Owner Name"
                                           Classes="label"/>
                                <TextBox Text="{Binding OwnerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Brand"
                                           Classes="label"/>
                                <TextBox Text="{Binding Brand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="3"
                                        Spacing="6">
                                <TextBlock Text="Model"
                                           Classes="label"/>
                                <TextBox Text="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="surfaceCard"
                        Padding="18">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Additional Details"
                                   Classes="sectionTitle"/>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="16"
                              RowDefinitions="Auto,Auto,Auto">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Mileage"
                                           Classes="label"/>
                                <TextBox Text="{Binding MileageText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="Normal Price"
                                           Classes="label"/>
                                <TextBox Text="{Binding NormalPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="6">
                                <TextBlock Text="Discounted Price"
                                           Classes="label"/>
                                <TextBox Text="{Binding DiscountedPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1"
                                        Spacing="6">
                                <TextBlock Text="Amount Paid"
                                           Classes="label"/>
                                <TextBox Text="{Binding AmountPaidText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Spacing="6">
                                <TextBlock Text="Notes"
                                           Classes="label"/>
                                <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         Height="110"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Classes="softCard"
                        Padding="14,12">
                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="muted"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1,1,0,0"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Required: vehicle number, promotion, and phone number."
                           VerticalAlignment="Center"
                           Classes="subtle"/>
                <Button Grid.Column="1"
                        Classes="secondary"
                        MinWidth="110"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        Classes="primary"
                        MinWidth="110"
                        Command="{Binding SaveCommand}"
                        Content="Save"/>
            </Grid>
        </Border>
    </Grid>
</Window>
