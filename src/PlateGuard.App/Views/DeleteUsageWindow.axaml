<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.DeleteUsageWindow"
        x:DataType="vm:DeleteUsageDialogViewModel"
        d:DesignWidth="620"
        d:DesignHeight="380"
        Title="Delete Record"
        Width="620"
        Height="380"
        MinWidth="580"
        MinHeight="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:DeleteUsageDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto"
          Background="#F1F5F9">
        <StackPanel Margin="20"
                    Spacing="16">
            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <StackPanel Spacing="8">
                    <TextBlock Text="Delete Record"
                               FontSize="26"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WarningMessage}"
                               Foreground="#475569"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="16"
                      RowDefinitions="Auto,Auto">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Vehicle Number"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VehicleNumberDisplay}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                        <TextBlock Text="Promotion"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PromotionName}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Margin="0,14,0,0"
                                Spacing="6">
                        <TextBlock Text="Delete Password"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding DeletePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="14,12">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#475569"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1,1,0,0"
                Padding="20,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Deleting this record restores eligibility for the same promotion."
                           VerticalAlignment="Center"
                           Foreground="#475569"/>
                <Button Grid.Column="1"
                        MinWidth="110"
                        Height="40"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        MinWidth="110"
                        Height="40"
                        Command="{Binding DeleteCommand}"
                        Content="Delete"/>
            </Grid>
        </Border>
    </Grid>
</Window>
