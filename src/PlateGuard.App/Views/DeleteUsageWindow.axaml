<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.DeleteUsageWindow"
        x:DataType="vm:DeleteUsageDialogViewModel"
        d:DesignWidth="600"
        d:DesignHeight="360"
        Title="Delete Record"
        Width="600"
        Height="360"
        MinWidth="560"
        MinHeight="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:DeleteUsageDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <StackPanel Margin="24"
                    Spacing="18">
            <Border Classes="statusBanner negative"
                    Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Delete Record"
                               Classes="pageTitle"/>
                    <TextBlock Text="{Binding WarningMessage}"
                               Classes="muted"/>
                </StackPanel>
            </Border>

            <Border Classes="surfaceCard"
                    Padding="18">
                <Grid ColumnDefinitions="*,*"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="16"
                      RowSpacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Vehicle Number"
                                   Classes="label"/>
                        <TextBlock Text="{Binding VehicleNumberDisplay}"
                                   Classes="value"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="4">
                        <TextBlock Text="Promotion"
                                   Classes="label"/>
                        <TextBlock Text="{Binding PromotionName}"
                                   Classes="value"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Spacing="6">
                        <TextBlock Text="Delete Password"
                                   Classes="label"/>
                        <TextBox Text="{Binding DeletePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PasswordChar="*"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Classes="softCard"
                    Padding="14,12">
                <TextBlock Text="{Binding StatusMessage}"
                           Classes="muted"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1,1,0,0"
                Padding="24,14">
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12">
                <TextBlock Text="Deleting restores eligibility for the same promotion."
                           VerticalAlignment="Center"
                           Classes="subtle"/>
                <Button Grid.Column="1"
                        Classes="secondary"
                        MinWidth="110"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"/>
                <Button Grid.Column="2"
                        Classes="danger"
                        MinWidth="110"
                        Command="{Binding DeleteCommand}"
                        Content="Delete"/>
            </Grid>
        </Border>
    </Grid>
</Window>
