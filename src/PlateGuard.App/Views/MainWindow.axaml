<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PlateGuard.App.ViewModels"
        xmlns:core="using:PlateGuard.Core.Models"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PlateGuard.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        d:DesignWidth="1320"
        d:DesignHeight="840"
        Background="{StaticResource BrushPageBackground}"
        Icon="/Assets/favicon.ico"
        Title="PlateGuard"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        Width="1240"
        Height="800"
        MinWidth="1080"
        MinHeight="720">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="250,*">
        <Border Grid.Column="0"
                Background="{StaticResource BrushSidebarBackground}"
                BorderBrush="{StaticResource BrushSidebarBorder}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Margin="16,18,16,14"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="10">
                    <Border Classes="softCard"
                            Background="#334155"
                            BorderBrush="#475569"
                            Padding="8"
                            VerticalAlignment="Top">
                        <Image Source="/Assets/logo.png"
                               Width="32"
                               Height="32"
                               Stretch="Uniform"/>
                    </Border>

                    <StackPanel Grid.Column="1"
                                Spacing="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="PlateGuard"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="8,0,8,0"
                            Spacing="4">
                    <Button Classes="nav"
                            Classes.selected="{Binding IsSearchSectionVisible}"
                            Command="{Binding ShowSearchSectionCommand}">
                        <Grid ColumnDefinitions="18,*"
                              ColumnSpacing="10">
                            <TextBlock Classes="iconGlyph"
                                       Text="&#xE721;"/>
                            <TextBlock Grid.Column="1"
                                       Text="Search"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Button>

                    <Button Classes="nav"
                            Classes.selected="{Binding IsPromotionsSectionVisible}"
                            Command="{Binding ShowPromotionsSectionCommand}">
                        <Grid ColumnDefinitions="18,*"
                              ColumnSpacing="10">
                            <TextBlock Classes="iconGlyph"
                                       Text="&#xE14C;"/>
                            <TextBlock Grid.Column="1"
                                       Text="Promotions"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Button>

                    <Button Classes="nav"
                            Classes.selected="{Binding IsHistorySectionVisible}"
                            Command="{Binding ShowHistorySectionCommand}">
                        <Grid ColumnDefinitions="18,*"
                              ColumnSpacing="10">
                            <TextBlock Classes="iconGlyph"
                                       Text="&#xE81C;"/>
                            <TextBlock Grid.Column="1"
                                       Text="History"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Button>

                    <Button Classes="nav"
                            Classes.selected="{Binding IsSettingsSectionVisible}"
                            Command="{Binding ShowSettingsSectionCommand}">
                        <Grid ColumnDefinitions="18,*"
                              ColumnSpacing="10">
                            <TextBlock Classes="iconGlyph"
                                       Text="&#xE713;"/>
                            <TextBlock Grid.Column="1"
                                       Text="Settings"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Margin="16,0,16,16"
                           Text="Offline | Windows | V1"
                           Foreground="{StaticResource BrushSidebarMuted}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Margin="20,18,22,20"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="24">
                <StackPanel IsVisible="{Binding IsSearchSectionVisible}"
                            Spacing="20">
                    <Grid ColumnDefinitions="*,320"
                          ColumnSpacing="20">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Search / Home"
                                       Classes="pageTitle"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Spacing="6">
                            <TextBlock Text="ACTIVE PROMOTION"
                                       Classes="label"/>
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="8">
                                <ComboBox Grid.Column="0"
                                          TabIndex="1"
                                          ItemsSource="{Binding ActivePromotions}"
                                          SelectedItem="{Binding SelectedPromotion, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="core:Promotion">
                                            <TextBlock Text="{Binding PromotionName}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Grid.Column="1"
                                        Classes="secondary"
                                        MinWidth="92"
                                        Command="{Binding RefreshPromotionsCommand}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Classes="iconGlyph"
                                                   Text="&#xE72C;"/>
                                        <TextBlock Text="Refresh"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Border Classes="heroCard"
                            Padding="16">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10"
                              RowDefinitions="Auto,Auto">
                            <StackPanel Spacing="6">
                                <Border Classes="searchHeroInputHost">
                                    <Grid>
                                        <TextBox x:Name="SearchInputTextBox"
                                                 TabIndex="0"
                                                 Classes="searchHeroBox"
                                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="Find vehicle, phone, or owner..."/>
                                        <TextBlock Classes="iconGlyph"
                                                   Margin="14,0,0,0"
                                                   FontSize="16"
                                                   Foreground="{StaticResource BrushAccentText}"
                                                   IsHitTestVisible="False"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   Text="&#xE721;"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Classes="secondary"
                                    Width="96"
                                    Height="56"
                                    VerticalAlignment="Bottom"
                                    Command="{Binding ClearSearchCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                    <TextBlock Classes="iconGlyph"
                                               Text="&#xE894;"/>
                                    <TextBlock Text="Clear"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="430,*"
                          ColumnSpacing="20">
                        <Border Classes="surfaceCard"
                                Padding="14"
                                MinHeight="300">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Text="Search Results"
                                           Classes="sectionTitle"/>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <ListBox IsVisible="{Binding HasSearchResults}"
                                             ItemsSource="{Binding SearchResults}"
                                             SelectedItem="{Binding SelectedVehicle, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="core:Vehicle">
                                                <Border BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="10,8">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          RowDefinitions="Auto,Auto"
                                                          ColumnSpacing="10"
                                                          RowSpacing="2">
                                                        <TextBlock Text="{Binding VehicleNumberRaw}"
                                                                   Classes="value"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding PhoneNumber}"
                                                                   Classes="muted"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding OwnerName}"
                                                                   Foreground="#2B3948"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Classes="subtle">
                                                            <Run Text="{Binding Brand}"/>
                                                            <Run Text=" "/>
                                                            <Run Text="{Binding Model}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid IsVisible="{Binding HasNoSearchResults}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="0,40">
                                        <shapes:Rectangle Stroke="#CBD5E1"
                                                          StrokeThickness="2"
                                                          StrokeDashArray="2,2"
                                                          RadiusX="8"
                                                          RadiusY="8"
                                                          Fill="Transparent"/>
                                        <StackPanel Margin="32,24"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding EmptyStateTitle}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="{Binding EmptyStateMessage}"
                                                       Classes="muted"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1"
                              RowDefinitions="Auto,Auto"
                              RowSpacing="16">
                            <Border Classes="surfaceCard"
                                    Padding="20">
                                <StackPanel Spacing="0">
                                    <TextBlock Text="Selected Vehicle"
                                               Classes="sectionTitle"/>

                                    <Border Margin="0,12,0,0"
                                            Padding="0,0,0,12"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="VEHICLE NUMBER"
                                                       Classes="label"/>
                                            <TextBlock Text="{Binding SelectedVehicleNumber}"
                                                       Classes="keyValue"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,0,0,0"
                                          ColumnDefinitions="*,*"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="16">
                                        <Border Grid.Row="0"
                                                Grid.Column="0"
                                                Padding="0,12,8,12"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="OWNER"
                                                           Classes="label"/>
                                                <TextBlock Text="{Binding SelectedVehicleOwner}"
                                                           Classes="value"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="0"
                                                Grid.Column="1"
                                                Padding="8,12,0,12"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="PHONE"
                                                           Classes="label"/>
                                                <TextBlock Text="{Binding SelectedVehiclePhone}"
                                                           Classes="value"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1"
                                                Grid.ColumnSpan="2"
                                                Padding="0,12,0,0">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="BRAND / MODEL"
                                                           Classes="label"/>
                                                <TextBlock Text="{Binding SelectedVehicleBrandModel}"
                                                           Classes="value"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1"
                                    Classes="statusBanner"
                                    Classes.success="{Binding IsEligibilityPositive}"
                                    Classes.negative="{Binding IsEligibilityNegative}"
                                    Classes.warning="{Binding IsEligibilityWarning}"
                                    Padding="16">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="14">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Eligibility"
                                                   Classes="eyebrow"/>
                                        <TextBlock Text="{Binding EligibilityTitle}"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Classes="primary"
                                            MinWidth="138"
                                            VerticalAlignment="Center"
                                            Command="{Binding AddUsageCommand}"
                                            Content="Add Usage"
                                            IsEnabled="{Binding CanAddUsage}"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <Border Classes="surfaceCard"
                            Padding="20">
                        <Grid RowDefinitions="Auto,*">
                            <TextBlock Text="Promotion History"
                                       Classes="sectionTitle"/>

                            <Grid Grid.Row="1"
                                  Margin="0,10,0,0">
                                <ListBox IsVisible="{Binding HasHistory}"
                                         ItemsSource="{Binding SelectedVehicleHistory}"
                                         MaxHeight="180">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:UsageHistoryItemViewModel">
                                            <Border BorderBrush="{StaticResource BrushBorder}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="10,8">
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="12">
                                                    <TextBlock Text="{Binding PromotionName}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ServiceDateText}"
                                                               Classes="muted"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding AmountPaidText}"
                                                               Classes="muted"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid IsVisible="{Binding HasNoHistory}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Margin="0,30">
                                    <shapes:Rectangle Stroke="#CBD5E1"
                                                      StrokeThickness="2"
                                                      StrokeDashArray="2,2"
                                                      RadiusX="8"
                                                      RadiusY="8"
                                                      Fill="Transparent"/>
                                    <StackPanel Margin="36,20"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock Text="No promotion history"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>
                                        <TextBlock Text="{Binding HistoryEmptyStateMessage}"
                                                   Classes="muted"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding StatusMessage}"
                               Classes="subtle"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsPromotionsSectionVisible}"
                            Spacing="20">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Promotions"
                                       Classes="pageTitle"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Classes="secondary"
                                MinWidth="96"
                                Command="{Binding RefreshPromotionManagementCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Classes="iconGlyph"
                                           Text="&#xE72C;"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Classes="primary"
                                MinWidth="146"
                                Command="{Binding AddPromotionCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Classes="iconGlyph"
                                           Text="&#xE710;"/>
                                <TextBlock Text="Add Promotion"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="380,*"
                          ColumnSpacing="20">
                        <Border Classes="surfaceCard"
                                Padding="20"
                                MinHeight="380">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Text="Promotion List"
                                           Classes="sectionTitle"/>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <ListBox IsVisible="{Binding HasPromotionManagementItems}"
                                             ItemsSource="{Binding PromotionManagementItems}"
                                             SelectedItem="{Binding SelectedPromotionManagementItem, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:PromotionManagementItemViewModel">
                                                <Border BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="10,8">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          RowDefinitions="Auto,Auto,Auto"
                                                          ColumnSpacing="10"
                                                          RowSpacing="2">
                                                        <TextBlock Text="{Binding PromotionName}"
                                                                   Classes="value"/>
                                                        <Border Grid.Column="1"
                                                                Classes="inlineTag"
                                                                Padding="8,3">
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       Classes="subtle"/>
                                                        </Border>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding ScheduleText}"
                                                                   Classes="muted"/>
                                                        <TextBlock Grid.Row="2"
                                                                   Grid.ColumnSpan="2"
                                                                   Text="{Binding UsageCountText}"
                                                                   Classes="subtle"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid IsVisible="{Binding HasNoPromotionManagementItems}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="0,40">
                                        <shapes:Rectangle Stroke="#CBD5E1"
                                                          StrokeThickness="2"
                                                          StrokeDashArray="2,2"
                                                          RadiusX="8"
                                                          RadiusY="8"
                                                          Fill="Transparent"/>
                                        <StackPanel Margin="40,28"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8">
                                            <TextBlock Text="{Binding PromotionManagementEmptyTitle}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="{Binding PromotionManagementEmptyMessage}"
                                                       Classes="muted"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <Button Classes="primary"
                                                    MinWidth="160"
                                                    HorizontalAlignment="Center"
                                                    Command="{Binding AddPromotionCommand}"
                                                    Content="Create Promotion"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Classes="surfaceCard"
                                Padding="20">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="14">
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="Selected Promotion"
                                               Classes="sectionTitle"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Classes="secondary"
                                            MinWidth="120"
                                            Command="{Binding EditSelectedPromotionCommand}"
                                            Content="Edit Promotion"
                                            IsEnabled="{Binding CanEditSelectedPromotion}"/>
                                    <Button Grid.Column="2"
                                            Classes="primary"
                                            MinWidth="120"
                                            Command="{Binding ToggleSelectedPromotionStatusCommand}"
                                            Content="{Binding TogglePromotionStatusButtonText}"
                                            IsEnabled="{Binding CanEditSelectedPromotion}"/>
                                </Grid>

                                <StackPanel Grid.Row="1"
                                            Spacing="0">
                                    <Border Padding="0,0,0,12"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="PROMOTION NAME"
                                                       Classes="label"/>
                                            <TextBlock Text="{Binding SelectedManagementPromotionName}"
                                                       Classes="keyValue"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0"
                                                Padding="0,12,8,12"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="STATUS"
                                                           Classes="label"/>
                                                <TextBlock Text="{Binding SelectedManagementPromotionStatus}"
                                                           Classes="value"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Padding="8,12,0,12"
                                                BorderBrush="{StaticResource BrushBorder}"
                                                BorderThickness="0,0,0,1">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="USAGE COUNT"
                                                           Classes="label"/>
                                                <TextBlock Text="{Binding SelectedManagementPromotionUsageCount}"
                                                           Classes="value"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Border Padding="0,12,0,12"
                                            BorderBrush="{StaticResource BrushBorder}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="DATE WINDOW"
                                                       Classes="label"/>
                                            <TextBlock Text="{Binding SelectedManagementPromotionWindow}"
                                                       Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="0,12,0,0">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="DESCRIPTION"
                                                       Classes="label"/>
                                            <TextBlock Text="{Binding SelectedManagementPromotionDescription}"
                                                       Classes="muted"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding PromotionManagementStatusMessage}"
                               Classes="subtle"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsHistorySectionVisible}"
                            Spacing="20">
                    <Grid ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10">
                        <StackPanel Spacing="4">
                            <TextBlock Text="History / Records"
                                       Classes="pageTitle"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Classes="secondary"
                                MinWidth="160"
                                Command="{Binding ExportFilteredHistoryRecordsCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Classes="iconGlyph"
                                           Text="&#xEDE1;"/>
                                <TextBlock Text="Export Filtered"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Classes="primary"
                                MinWidth="132"
                                Command="{Binding ExportAllHistoryRecordsCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Classes="iconGlyph"
                                           Text="&#xEDE1;"/>
                                <TextBlock Text="Export All"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Classes="softCard"
                            Padding="12">
                        <Grid ColumnDefinitions="2*,*,Auto,Auto,Auto,Auto"
                              ColumnSpacing="8"
                              VerticalAlignment="Center">
                            <TextBox VerticalAlignment="Center"
                                     Text="{Binding HistorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="Search by vehicle number, phone, owner, or promotion"/>
                            <ComboBox Grid.Column="1"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding HistoryPromotionFilters}"
                                      SelectedItem="{Binding SelectedHistoryPromotionFilter, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HistoryPromotionFilterOptionViewModel">
                                        <TextBlock Text="{Binding Label}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Grid.Column="2"
                                     VerticalAlignment="Center"
                                     Padding="12,0"
                                     Width="132"
                                     Text="{Binding HistoryDateFromText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="From yyyy-MM-dd"/>
                            <TextBox Grid.Column="3"
                                     VerticalAlignment="Center"
                                     Padding="12,0"
                                     Width="132"
                                     Text="{Binding HistoryDateToText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="To yyyy-MM-dd"/>
                            <Button Grid.Column="4"
                                    Classes="secondary"
                                    VerticalAlignment="Center"
                                    MinWidth="96"
                                    Command="{Binding ClearHistoryFiltersCommand}"
                                    Content="Clear"/>
                            <Button Grid.Column="5"
                                    Classes="secondary"
                                    VerticalAlignment="Center"
                                    MinWidth="96"
                                    Command="{Binding RefreshHistoryRecordsCommand}"
                                    Content="Refresh"/>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="500,*"
                          ColumnSpacing="20">
                        <Border Classes="surfaceCard"
                                Padding="20"
                                MinHeight="430">
                            <Grid RowDefinitions="Auto,*">
                                <TextBlock Text="Records"
                                           Classes="sectionTitle"/>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0">
                                    <ListBox IsVisible="{Binding HasHistoryRecords}"
                                             ItemsSource="{Binding HistoryRecords}"
                                             SelectedItem="{Binding SelectedHistoryRecord, Mode=TwoWay}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:HistoryRecordItemViewModel">
                                                <Border BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="10,8">
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          RowDefinitions="Auto,Auto,Auto"
                                                          ColumnSpacing="10"
                                                          RowSpacing="2">
                                                        <TextBlock Text="{Binding VehicleNumberDisplay}"
                                                                   Classes="value"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding ServiceDateText}"
                                                                   Classes="muted"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Text="{Binding PromotionName}"
                                                                   Foreground="#2B3948"/>
                                                        <TextBlock Grid.Row="1"
                                                                   Grid.Column="1"
                                                                   Text="{Binding AmountPaidText}"
                                                                   Classes="muted"/>
                                                        <TextBlock Grid.Row="2"
                                                                   Grid.ColumnSpan="2"
                                                                   Classes="muted">
                                                            <Run Text="{Binding OwnerName}"/>
                                                            <Run Text=" | "/>
                                                            <Run Text="{Binding PhoneNumber}"/>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid IsVisible="{Binding HasNoHistoryRecords}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Margin="0,40">
                                        <shapes:Rectangle Stroke="#CBD5E1"
                                                          StrokeThickness="2"
                                                          StrokeDashArray="2,2"
                                                          RadiusX="8"
                                                          RadiusY="8"
                                                          Fill="Transparent"/>
                                        <StackPanel Margin="40,24"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Spacing="4">
                                            <TextBlock Text="{Binding HistoryRecordsEmptyTitle}"
                                                       FontSize="17"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="{Binding HistoryRecordsEmptyMessage}"
                                                       Classes="muted"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                Classes="surfaceCard"
                                Padding="20">
                            <Grid RowDefinitions="Auto,*"
                                  RowSpacing="14">
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="Selected Record"
                                               Classes="sectionTitle"
                                               VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Classes="secondary"
                                            MinWidth="104"
                                            Command="{Binding EditSelectedHistoryRecordCommand}"
                                            Content="Edit"
                                            IsEnabled="{Binding CanEditSelectedHistoryRecord}"/>
                                    <Button Grid.Column="2"
                                            Classes="danger"
                                            MinWidth="104"
                                            Command="{Binding DeleteSelectedHistoryRecordCommand}"
                                            Content="Delete"
                                            IsEnabled="{Binding CanDeleteSelectedHistoryRecord}"/>
                                </Grid>

                                <Grid Grid.Row="1"
                                      ColumnDefinitions="*,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="18"
                                      RowSpacing="0">
                                    <Border Grid.Row="0" Grid.Column="0" Padding="0,12,8,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="VEHICLE NUMBER" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryVehicleNumber}" Classes="keyValue"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Padding="8,12,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="PROMOTION" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryPromotionName}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Padding="0,12,8,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="SERVICE DATE" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryServiceDate}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Padding="8,12,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="STATUS" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryRecordStatus}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="0" Padding="0,12,8,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="OWNER" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryOwner}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="2" Grid.Column="1" Padding="8,12,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="PHONE" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryPhone}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3" Grid.Column="0" Padding="0,12,8,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="BRAND / MODEL" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryBrandModel}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="3" Grid.Column="1" Padding="8,12,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="MILEAGE" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryMileage}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="4" Grid.Column="0" Padding="0,12,8,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="AMOUNT PAID" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryAmountPaid}" Classes="value"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="4" Grid.Column="1" Padding="8,12,0,12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="PRICING" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryPricing}" Classes="muted"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="5" Grid.ColumnSpan="2" Padding="0,12,0,0">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="NOTES" Classes="label"/>
                                            <TextBlock Text="{Binding SelectedHistoryNotes}" Classes="muted"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <TextBlock Text="{Binding HistoryRecordsStatusMessage}"
                               Classes="subtle"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsSettingsSectionVisible}"
                            Spacing="18">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Settings"
                                   Classes="pageTitle"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="Auto,Auto"
                          ColumnSpacing="20"
                          HorizontalAlignment="Left">
                        <Border Classes="surfaceCard"
                                Padding="20"
                                Width="450"
                                VerticalAlignment="Top">
                            <StackPanel Spacing="14">
                                <TextBlock Text="General"
                                           Classes="sectionTitle"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="SHOP NAME"
                                               Classes="label"/>
                                    <TextBox Text="{Binding SettingsShopName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Optional shop name"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="DEFAULT EXPORT FOLDER"
                                               Classes="label"/>
                                    <TextBox Text="{Binding SettingsExportFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Optional full folder path"/>
                                </StackPanel>

                                <Button Classes="primary"
                                        Width="150"
                                        HorizontalAlignment="Left"
                                        Command="{Binding SaveSettingsCommand}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Classes="iconGlyph"
                                                   Text="&#xE74E;"/>
                                        <TextBlock Text="Save Settings"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Classes="surfaceCard"
                                Padding="20"
                                Width="450"
                                VerticalAlignment="Top">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Delete Password"
                                           Classes="sectionTitle"/>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="CURRENT PASSWORD"
                                               Classes="label"/>
                                    <TextBox Text="{Binding CurrentDeletePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PasswordChar="*"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="NEW PASSWORD"
                                               Classes="label"/>
                                    <TextBox Text="{Binding NewDeletePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PasswordChar="*"/>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="CONFIRM NEW PASSWORD"
                                               Classes="label"/>
                                    <TextBox Text="{Binding ConfirmDeletePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PasswordChar="*"/>
                                </StackPanel>

                                <Button Classes="primary"
                                        Width="178"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ChangeDeletePasswordCommand}">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <TextBlock Classes="iconGlyph"
                                                   Text="&#xE72E;"/>
                                        <TextBlock Text="Change Password"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
